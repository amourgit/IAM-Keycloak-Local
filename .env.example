# =============================================================================
# EIGEN IAM — Variables d'environnement :: Keycloak Local
# Copier en `.env` et adapter pour chaque établissement.
# NE JAMAIS committer le fichier `.env` en clair dans Git.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# IDENTITÉ DE L'ÉTABLISSEMENT (obligatoire)
# ─────────────────────────────────────────────────────────────────────────────
# Code court unique de l'établissement (minuscules, sans espaces)
# Exemples : uob, esga, insg, ustm, ensa, iut-lb
ETABLISSEMENT_CODE=uob

# Nom complet affiché dans l'interface
ETABLISSEMENT_NOM=Université Omar Bongo

# ─────────────────────────────────────────────────────────────────────────────
# KEYCLOAK LOCAL
# ─────────────────────────────────────────────────────────────────────────────
# Admin bootstrap — désactiver après la première configuration
KC_ADMIN_USER=eigen-admin-local
KC_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Hostname public de ce Keycloak Local
# En développement : localhost ou 127.0.0.1
# En production : sso.uob.eigen.ga
KC_HOSTNAME=sso.uob.eigen.ga

# Ports exposés (hôte Docker)
KC_HTTP_PORT_EXPOSE=8090
KC_HTTPS_PORT_EXPOSE=8453

# Niveau de log
KC_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────
KC_DB_NAME=keycloak_local_uob
KC_DB_USER=kc_local_uob_usr
KC_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ─────────────────────────────────────────────────────────────────────────────
# REDIS — GESTION DES SESSIONS
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
REDIS_PORT_EXPOSE=6379

# Durée de vie des sessions actives en Redis (secondes)
# 86400 = 24 heures
SESSION_TTL_SECONDS=86400

# ─────────────────────────────────────────────────────────────────────────────
# CONNEXION KEYCLOAK CENTRAL
# ─────────────────────────────────────────────────────────────────────────────
# URL de Keycloak Central (sans slash final)
KC_CENTRAL_URL=https://sso.eigen.ga

# ─────────────────────────────────────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────────────────────────────────────
# Adresse du broker Kafka (partagé avec Keycloak Central ou instance locale)
KAFKA_BOOTSTRAP=kafka-central:9092

# ─────────────────────────────────────────────────────────────────────────────
# ACTIVE DIRECTORY / LDAP (optionnel — laisser vide si non applicable)
# ─────────────────────────────────────────────────────────────────────────────
# Mettre true uniquement si l'établissement a un annuaire LDAP/AD
LDAP_ENABLED=false

# Si LDAP_ENABLED=true, remplir les paramètres suivants :
LDAP_URL=ldap://ad.uob.ga:389
LDAP_BIND_DN=cn=keycloak-reader,ou=service-accounts,dc=uob,dc=ga
LDAP_BIND_CREDENTIAL=CHANGE_ME_IN_PRODUCTION
LDAP_USERS_DN=ou=personnels,dc=uob,dc=ga

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS CLIENTS KEYCLOAK
# ─────────────────────────────────────────────────────────────────────────────
# Secret du client gateway-{etablissement_code}
EIGEN_GATEWAY_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION

# Secret du client eigen-referentiel-service (local)
EIGEN_REFERENTIEL_LOCAL_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION

# ─────────────────────────────────────────────────────────────────────────────
# EIGEN SYSTÈME
# ─────────────────────────────────────────────────────────────────────────────
EIGEN_VERSION=1.0.0
